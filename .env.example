# Server
INROAD_ENV=development
INROAD_HTTP_ADDR=:8080

# Postgres
# Dev DB (make db-up) is published on host port 5433 to avoid clashing with a
# native Postgres on 5432. The full `docker compose up` stack uses the internal
# network (postgres:5432) and is unaffected.
INROAD_DATABASE_URL=postgres://inroad:inroad@localhost:5433/inroad?sslmode=disable

# Redis
INROAD_REDIS_ADDR=localhost:6379

# Auth — generate with: openssl rand -base64 32
INROAD_JWT_SECRET=replace-me-with-32-byte-secret

# Envelope encryption master key (base64 of 32 raw bytes) — openssl rand -base64 32
INROAD_MASTER_KEY=replace-me-with-base64-32-bytes
